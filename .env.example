# Скопируйте в .env и заполните значения. .env не коммитится в git.

# --- Секреты ---
TELEGRAM_TOKEN=
BYBIT_API_KEY=
BYBIT_API_SECRET=
DEEPSEEK_API_KEY=

# --- Логирование (опционально, по умолчанию: INFO / 20 МБ / 3 архива) ---
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
LOG_MAX_FILE_SIZE_MB=20
LOG_BACKUP_COUNT=3

# --- Telegram-бот: режим работы ---
# polling — без публичного домена (по умолчанию)
# webhook — для production за HTTPS reverse proxy
BOT_MODE=polling

# Параметры webhook (используются только при BOT_MODE=webhook)
# WEBHOOK_URL — публичный URL вашего сервера (https), без слеша на конце
WEBHOOK_URL=
# Путь, по которому Telegram будет POST'ить апдейты. Сделайте «секретным».
WEBHOOK_PATH=/telegram-webhook
# Адрес, на котором слушает контейнер бота
WEBHOOK_LISTEN=0.0.0.0
# Порт внутри контейнера (за reverse proxy)
WEBHOOK_PORT=8443
# Секретный заголовок (рекомендуется — Telegram пришлёт его в X-Telegram-Bot-Api-Secret-Token)
WEBHOOK_SECRET_TOKEN=
BOT_DROP_PENDING_UPDATES=true
